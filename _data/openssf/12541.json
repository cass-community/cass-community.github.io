{"id":12541,"user_id":49486,"name":"PETSc","description":"PETSc, the Portable, Extensible Toolkit for Scientific Computation, pronounced, is for the scalable (parallel) solution of scientific applications modeled by partial differential equations (PDEs). It has bindings for C, Fortran, and Python (via petsc4py). PETSc also contains TAO, the Toolkit for Advanced Optimization, software library. They support MPI, and GPUs through CUDA, HIP, Kokkos, as well as hybrid MPI-GPU parallelism; they also support the NEC-SX Tsubasa Vector Engine.","homepage_url":"https://petsc.org","repo_url":"https://gitlab.com/petsc/petsc","license":"BSD-2-Clause","homepage_url_status":"?","homepage_url_justification":null,"sites_https_status":"Met","sites_https_justification":"Given only https: URLs.","description_good_status":"Met","description_good_justification":"https://petsc.org/release/overview/","interact_status":"Met","interact_justification":"* Install:  \r\n  https://petsc.org/release/install/\r\n* Reporting Bugs, Asking Questions, and Making Suggestions\r\n  https://petsc.org/release/community/mailing/\r\n* Contributing to PETSc\r\n  https://petsc.org/release/developers/contributing/\r\n\r\n\r\n","contribution_status":"Met","contribution_requirements_status":"Met","license_location_status":"?","floss_license_status":"Met","floss_license_justification":"The BSD-2-Clause license is approved by the Open Source Initiative (OSI).","floss_license_osi_status":"Met","floss_license_osi_justification":"The BSD-2-Clause license is approved by the Open Source Initiative (OSI).","documentation_basics_status":"?","documentation_interface_status":"?","repo_public_status":"Met","repo_track_status":"?","repo_interim_status":"?","repo_distributed_status":"?","version_unique_status":"?","version_semver_status":"?","version_tags_status":"?","release_notes_status":"?","release_notes_vulns_status":"?","report_url_status":"?","report_url_justification":null,"report_tracker_status":"?","report_process_st